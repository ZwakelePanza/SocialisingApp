<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/background_gradient">

    <!--Luyanda Ross ST10530303-->

    <!-- App Title -->
    <TextView
        android:id="@+id/textviewTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:letterSpacing="0.05"
        android:text="@string/social_sparks"
        android:textColor="#00E5FF"
        android:textSize="32sp"
        android:textStyle="bold"
        tools:ignore="TextContrastCheck" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/textviewWelcome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"
        android:gravity="center"
        android:text="@string/discover_exciting_social_ideas"
        android:textColor="#CBD5F5"
        android:textSize="14sp"
        tools:ignore="TextContrastCheck" />

    <!--Mood-->
    <LinearLayout
        android:id="@+id/linearLayoutMood"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_card_glass">
        <TextView
            android:id="@+id/MoodQuestion"
            style="?android:attr/buttonBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hey_how_are_you_doing_today"
            android:textColor="#E0F7FA"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnGood"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/mood_good"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/bg_button_gradient"
                android:elevation="8dp"
                tools:ignore="ButtonStyle,VisualLintButtonSize" />

            <Button
                android:id="@+id/btnNotGood"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/mood_not_good"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                tools:ignore="ButtonStyle,TextSizeCheck,VisualLintButtonSize" />
        </LinearLayout>

        <TextView
            android:id="@+id/MoodResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#B2EBF2"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Input Field -->
    <EditText
        android:id="@+id/editTextTime"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="24dp"
        android:autofillHints=""
        android:background="@drawable/bg_input_rounded"
        android:hint="@string/enter_time_e_g_morning"
        android:inputType="textPersonName"
        android:padding="16dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#94A3B8"
        tools:ignore="VisualLintTextFieldSize,TextContrastCheck" />



    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/buttonSuggest"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_gradient"
            android:text="@string/suggestions"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:elevation="8dp"
            tools:ignore="VisualLintButtonSize" />

        <Space
            android:layout_width="12dp"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/buttonReset"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_button_secondary"
            android:text="@string/resetbutton"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            tools:ignore="VisualLintButtonSize"
            android:elevation="8dp"/>
    </LinearLayout>

    <!--Typing Effect-->
    <TextView
        android:id="@+id/TypingEffect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/typing"
        android:textColor="#94A3B8"
        android:textStyle="italic"
        android:textSize="14sp"
        android:visibility="gone"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"/>


    <!-- Result Card -->
    <TextView
        android:id="@+id/TextViewSuggestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_card_glass"
        android:gravity="center"
        android:padding="20dp"
        android:text="@string/your_suggestion_will_appear_here"
        android:textColor="#E2E8F0"
        android:textSize="16sp" />

</LinearLayout>