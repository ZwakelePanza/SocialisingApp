<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!--Base Dark Gradient-->
    <item>
        <!--suppress AndroidElementNotAllowed, AndroidElementNotAllowed -->
        <shape>
            <!--suppress AndroidElementNotAllowed -->
            <gradient
                android:startColor="#020617"
                android:centerColor="#1E1B4B"
                android:endColor="#0F172A"
                android:angle="270"/>
        </shape>
    </item>

    <!--GlOW Circle (Top Right)-->
    <item android:gravity="top|end">
        <shape android:shape="oval">
            <size android:width="300dp" android:height="300dp"/>
            <gradient
                android:type="radial"
                android:gradientRadius="200dp"
                android:startColor="#7C3AED"
                android:endColor="#00000000"/>
        </shape>
    </item>

    <!--GlOW Circle (Top Left)-->
    <item android:gravity="top|start">
        <shape android:shape="oval">
            <size android:width="250dp" android:height="250dp"/>
            <gradient
                android:type="radial"
                android:gradientRadius="180dp"
                android:startColor="#9333EA"
                android:endColor="#00000000"/>
        </shape>
    </item>
</layer-list>